{
  "manifest_version": 3,
  "name": "Dealership Marketplace Helper",
  "version": "0.3.4",
  "description": "Scrape dealership inventory pages and prepare Facebook Marketplace drafts.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "https://www.facebook.com/*",
    "https://facebook.com/*",
    "https://api.bertogden123.com/*",
    "https://dealership-tool-api.onrender.com/*",
    "https://*.carscommerce.inc/*",
    "https://www.bertogdenmissionkia.com/*",
    "https://www.bertogdenmissionmazda.com/*",
    "https://www.bertogdenmission.com/*",
    "https://www.bertogdenmissionautooutlet.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.bertogdenmissionkia.com/*",
        "https://www.bertogdenmissionmazda.com/*",
        "https://www.bertogdenmission.com/*",
        "https://www.bertogdenmissionautooutlet.com/*"
      ],
      "js": ["inventory.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.facebook.com/marketplace/*",
        "https://facebook.com/marketplace/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
